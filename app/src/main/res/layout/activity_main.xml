<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/Header"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:text="Bem-vindo!"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="20dp"
        android:layout_marginStart="20dp"
        android:textStyle="bold"
        android:textSize="20dp" />

    <TextView
        android:id="@+id/Vers"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:text="Emergência v1.0"
        android:textSize="8dp"
        android:paddingBottom="3dp"
        android:textAlignment="center"
        app:layout_constraintBottom_toBottomOf="@id/Header"
        app:layout_constraintStart_toEndOf="@id/Header" />

    <Button
        android:id="@+id/PM"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="190 - Policia Militar (PM)"
        android:textSize="12dp"
        android:textAlignment="textStart"
        app:layout_constraintTop_toBottomOf="@id/Header"
        android:layout_marginTop="30dp" />

    <Button
        android:id="@+id/PRF"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="191 - Policia Rodoviária Federal (PRF)"
        android:textSize="12dp"
        android:textAlignment="textStart"
        app:layout_constraintTop_toBottomOf="@id/PM" />

    <Button
        android:id="@+id/PRE"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="198 - Policia Rodoviária Estadual (PRE)"
        android:textSize="12dp"
        android:textAlignment="textStart"
        app:layout_constraintTop_toBottomOf="@id/PRF" />


    <Button
        android:id="@+id/SAMU"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="192 - Serviço de Atendimento Móvel Urgente (SAMU)"
        android:textSize="12dp"
        android:textAlignment="textStart"
        app:layout_constraintTop_toBottomOf="@id/PRE" />

    <Button
        android:id="@+id/CB"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="193 - Corpo de Bombeiros"
        android:textSize="12dp"
        android:textAlignment="textStart"
        app:layout_constraintTop_toBottomOf="@id/SAMU" />

    <Button
        android:id="@+id/DC"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="199 - Defesa Civil"
        android:textSize="12dp"
        android:textAlignment="textStart"
        app:layout_constraintTop_toBottomOf="@id/CB" />

    <Button
        android:id="@+id/CAM"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="180 - Central de Atendimento a Mulher"
        android:textSize="12dp"
        android:textAlignment="textStart"
        app:layout_constraintTop_toBottomOf="@id/DC" />

    <Button
        android:id="@+id/DDH"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="100 - Disque Direitos Humanos"
        android:textSize="12dp"
        android:textAlignment="textStart"
        app:layout_constraintTop_toBottomOf="@id/CAM" />

    <Button
        android:id="@+id/PROCON"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="151 - Programa de Prot. e Def. do Consumidor (PROCON)"
        android:textSize="12dp"
        android:textAlignment="textStart"
        app:layout_constraintTop_toBottomOf="@id/DDH" />

    <Button
        android:id="@+id/CVV"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="141 - Centro de Valorização da Vida"
        android:textSize="12dp"
        android:textAlignment="textStart"
        app:layout_constraintTop_toBottomOf="@id/PROCON" />

</androidx.constraintlayout.widget.ConstraintLayout>